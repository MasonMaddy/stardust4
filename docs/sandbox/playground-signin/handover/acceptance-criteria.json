{
  "$description": "Flat, agent-checkable acceptance criteria for \"Playground Sign-in\". Generated by scripts/build-handoff.mjs.",
  "flow": "playground-signin",
  "version": "0.1",
  "count": 16,
  "criteria": [
    {
      "id": "S1-AC1",
      "screen": "S1",
      "text": "Sign in is disabled until both fields have content.",
      "assert": "signin.enabled == (username.length>0 AND password.length>0)"
    },
    {
      "id": "S1-AC2",
      "screen": "S1",
      "text": "Valid credentials show the loading state then route to S2.",
      "assert": "submit(valid) -> loading shown -> route==S2 within ~1200ms"
    },
    {
      "id": "S1-AC3",
      "screen": "S1",
      "text": "Invalid credentials show the inline service error and stay on S1.",
      "assert": "submit(invalid) -> alert==e-creds visible AND route==S1"
    },
    {
      "id": "S1-AC4",
      "screen": "S1",
      "text": "Password reveal toggle flips the field between masked and plain.",
      "assert": "toggle -> password.inputType flips secure<->plain"
    },
    {
      "id": "S2-AC1",
      "screen": "S2",
      "text": "Selecting an educator routes to S4 carrying that educator.",
      "assert": "tap(educator[i]) -> route==S4 AND ctx.educator==educator[i]"
    },
    {
      "id": "S2-AC2",
      "screen": "S2",
      "text": "A search with no matches shows the no-match line.",
      "assert": "search('zzz') -> list.empty AND noMatch.visible"
    },
    {
      "id": "S2-AC3",
      "screen": "S2",
      "text": "The add-educator row opens S3.",
      "assert": "tap(addRow) -> route==S3"
    },
    {
      "id": "S3-AC1",
      "screen": "S3",
      "text": "Sign in is disabled until both fields have content.",
      "assert": "signin.enabled == (field1.length>0 AND field2.length>0)"
    },
    {
      "id": "S3-AC2",
      "screen": "S3",
      "text": "Successful add routes to S5.",
      "assert": "submit(valid) -> route==S5"
    },
    {
      "id": "S4-AC1",
      "screen": "S4",
      "text": "Entering the 4th digit auto-submits without a button.",
      "assert": "pin.length==4 -> submit fires automatically"
    },
    {
      "id": "S4-AC2",
      "screen": "S4",
      "text": "A correct PIN advances to S5 (cold start).",
      "assert": "submit(correct) AND scenario!=return -> route==S5"
    },
    {
      "id": "S4-AC3",
      "screen": "S4",
      "text": "An incorrect PIN shows the incorrect message and increments attempts.",
      "assert": "submit(incorrect) -> incorrectMsg.visible AND attempts++"
    },
    {
      "id": "S5-AC1",
      "screen": "S5",
      "text": "Continue is disabled until a room is selected.",
      "assert": "continue.enabled == (room != null)"
    },
    {
      "id": "S5-AC2",
      "screen": "S5",
      "text": "Continue routes to the Room Hub with the selected room in context.",
      "assert": "tap(continue) -> route==hub AND ctx.room==selected"
    },
    {
      "id": "S6-AC1",
      "screen": "S6",
      "text": "The remembered room is pre-selected and Continue routes to the hub.",
      "assert": "room==remembered AND tap(continue) -> route==hub"
    },
    {
      "id": "S6-AC2",
      "screen": "S6",
      "text": "Change room opens the full room list (S5).",
      "assert": "tap(changeRoom) -> route==S5"
    }
  ]
}

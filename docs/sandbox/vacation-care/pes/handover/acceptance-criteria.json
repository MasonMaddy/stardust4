{
  "$description": "Flat, agent-checkable acceptance criteria for \"Vacation Care — PES (Simplify Bookings)\". Generated by scripts/build-handoff.mjs.",
  "flow": "pes",
  "version": "0.1",
  "count": 11,
  "criteria": [
    {
      "id": "S1-AC1",
      "screen": "S1",
      "text": "Review is disabled until child + session + ≥1 date.",
      "assert": "button[Review][disabled] until child && session && dates.length>=1"
    },
    {
      "id": "S1-AC2",
      "screen": "S1",
      "text": "Dates field appears only after a session is chosen.",
      "assert": "Dates field hidden while session==null"
    },
    {
      "id": "S1-AC3",
      "screen": "S1",
      "text": "Changing session clears selected dates.",
      "assert": "pickSession() -> dates == []"
    },
    {
      "id": "S2-AC1",
      "screen": "S2",
      "text": "Selecting a child returns to S1 with it set.",
      "assert": "tap(child) -> route==S1 AND ctx.child==child"
    },
    {
      "id": "S3-AC1",
      "screen": "S3",
      "text": "'Request a space' marks the booking as waitlist.",
      "assert": "pick('Request a space') -> session.waitlist==true"
    },
    {
      "id": "S4-AC1",
      "screen": "S4",
      "text": "Disabled and out-of-month days can't be selected.",
      "assert": "tap(disabledDay) -> dates unchanged"
    },
    {
      "id": "S4-AC2",
      "screen": "S4",
      "text": "Save is disabled until ≥1 date selected.",
      "assert": "button[Save][disabled] while dates.length==0"
    },
    {
      "id": "S4-AC3",
      "screen": "S4",
      "text": "Selected day fill matches its kind.",
      "assert": "available->orange-500 fill; waitlist->purple-550 fill"
    },
    {
      "id": "S5-AC1",
      "screen": "S5",
      "text": "Waitlist total is £0.00 and shows the pill.",
      "assert": "session.waitlist -> total==0 AND 'Waitlist only' visible"
    },
    {
      "id": "S5-AC2",
      "screen": "S5",
      "text": "Priced total = price × dates.",
      "assert": "!waitlist -> total == price * dates.length"
    },
    {
      "id": "S6-AC1",
      "screen": "S6",
      "text": "Done resets the flow.",
      "assert": "Done -> route==S1 AND child/session/dates cleared"
    }
  ]
}

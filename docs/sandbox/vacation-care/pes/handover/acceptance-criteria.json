{
  "$description": "Flat, agent-checkable acceptance criteria for \"Vacation Care — PES (mobile booking)\". Generated by scripts/build-handoff.mjs.",
  "flow": "pes",
  "version": "0.2",
  "count": 11,
  "criteria": [
    {
      "id": "S1-AC1",
      "screen": "S1",
      "text": "‘New’ opens the booking form.",
      "assert": "tap(New) -> route==S2"
    },
    {
      "id": "S1-AC2",
      "screen": "S1",
      "text": "Today is the only filled calendar day; dots mark bookings.",
      "assert": "filledDay==16 AND dots on JULY_DOTS days"
    },
    {
      "id": "S2-AC1",
      "screen": "S2",
      "text": "Review disabled until child + ≥1 session.",
      "assert": "button[Review][disabled] until child && sessions.length>=1"
    },
    {
      "id": "S2-AC2",
      "screen": "S2",
      "text": "Session(s) field shows the count and can be cleared.",
      "assert": "value=='{n} sessions selected'; clear-X -> sessions==[]"
    },
    {
      "id": "S3-AC1",
      "screen": "S3",
      "text": "Selecting a child returns to S2 with it set.",
      "assert": "tap(child) -> route==S2 AND ctx.child==child"
    },
    {
      "id": "S4-AC1",
      "screen": "S4",
      "text": "Save disabled until ≥1 selected.",
      "assert": "button[Save][disabled] while selected==0"
    },
    {
      "id": "S4-AC2",
      "screen": "S4",
      "text": "Selection round-trips to S2.",
      "assert": "Save -> S2 field == '{n} sessions selected'"
    },
    {
      "id": "S5-AC1",
      "screen": "S5",
      "text": "Subtotal counts available sessions only.",
      "assert": "subtotal == sum(fee where !waitlist)"
    },
    {
      "id": "S5-AC2",
      "screen": "S5",
      "text": "TOTAL NOW = subtotal − 10%.",
      "assert": "total == subtotal*0.9"
    },
    {
      "id": "S5-AC3",
      "screen": "S5",
      "text": "Removing an item recomputes the total.",
      "assert": "remove(item) -> total reflects remaining available fees"
    },
    {
      "id": "S6-AC1",
      "screen": "S6",
      "text": "Cancel Booking returns to S1.",
      "assert": "tap(Cancel Booking) -> route==S1 AND state reset"
    }
  ]
}

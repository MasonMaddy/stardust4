  "props": [
    {
      "figmaProperty": "align",
      "values": "start, end",
      "default": "start",
      "codeProp": ".ds-menu-anchor / .ds-menu-anchor--end (code: align)"
    },
    {
      "figmaProperty": "open",
      "values": "false, true",
      "default": "false",
      "codeProp": ".is-open on the anchor (absent = hidden; code: open)"
    },
    {
      "figmaProperty": "role",
      "values": "menu, listbox",
      "default": "menu",
      "codeProp": "role on .ds-menu (menuitem vs option rows)"
    },
    {
      "figmaProperty": "item.icon",
      "values": "icon (optional)",
      "default": "—",
      "codeProp": ".ds-menu__icon slot inside .ds-menu__item"
    },
    {
      "figmaProperty": "item.disabled",
      "values": "false, true",
      "default": "false",
      "codeProp": "aria-disabled=\"true\" on .ds-menu__item"
    },
    {
      "figmaProperty": "item.selected",
      "values": "false, true",
      "default": "false",
      "codeProp": "aria-selected=\"true\" (listbox rows) → cyan tint"
    },
    {
      "figmaProperty": "multiSelect",
      "values": "false, true",
      "default": "false",
      "codeProp": ".ds-menu__item--multi (checkbox on the right)"
    },
    {
      "figmaProperty": "divider",
      "values": "—",
      "default": "—",
      "codeProp": ".ds-menu__divider between items"
    },
    {
      "figmaProperty": "— (code-only)",
      "values": "—",
      "default": "—",
      "codeProp": ".ds-menu--static forces the list visible (docs / show-all grids)"
    }
  ]
}

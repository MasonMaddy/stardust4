  "props": [
    {
      "figmaProperty": "align",
      "values": "start, center, end",
      "default": "start",
      "codeProp": ".ds-tabs--{align} (code: align)"
    },
    {
      "figmaProperty": "scrollable",
      "values": "false, true",
      "default": "false",
      "codeProp": ".ds-tabs--scrollable (code: scrollable)"
    },
    {
      "figmaProperty": "items",
      "values": "array of { label, disabled }",
      "default": "—",
      "codeProp": "one .ds-tabs__tab + .ds-tabs__panel per item (code: items)"
    },
    {
      "figmaProperty": "selected",
      "values": "tab index",
      "default": "first enabled",
      "codeProp": ".ds-tabs__tab--active + aria-selected=\"true\" (code: active)"
    },
    {
      "figmaProperty": "disabled (per tab)",
      "values": "false, true",
      "default": "false",
      "codeProp": ".ds-tabs__tab--disabled + aria-disabled=\"true\" (code: item.disabled)"
    },
    {
      "figmaProperty": "— (runtime-only)",
      "values": "false, true",
      "default": "false",
      "codeProp": ".ds-tabs--fade-start / --fade-end — toggled from scroll position on --scrollable"
    }
  ]

  "props": [
    {
      "figmaProperty": "direction",
      "values": "operational",
      "default": "operational",
      "codeProp": ".ds-calendar--{direction} — v1 ships operational only (code: direction)"
    },
    {
      "figmaProperty": "density",
      "values": "comfortable, compact",
      "default": "comfortable",
      "codeProp": ".ds-calendar--dense = compact (tighter cells, fewer chips) (code: dense)"
    },
    {
      "figmaProperty": "presentation",
      "values": "grid, agenda",
      "default": "grid",
      "codeProp": ".ds-calendar--agenda = the phone day-grouped list (code: presentation)"
    },
    {
      "figmaProperty": "value",
      "values": "date | null",
      "default": "null",
      "codeProp": "the selected day; renders .ds-calendar__day--selected and opens the panel/sheet (code: value)"
    },
    {
      "figmaProperty": "events",
      "values": "Event[]",
      "default": "—",
      "codeProp": "each { date, category, label } renders a .ds-calendar__event--{category} chip (code: events)"
    },
    {
      "figmaProperty": "category",
      "values": "bookings, staffing, closures",
      "default": "—",
      "codeProp": "an event's category → chip / dot / border colour (code: event.category)"
    },
    {
      "figmaProperty": "weekStart",
      "values": "monday, sunday",
      "default": "monday",
      "codeProp": "first grid column; default Monday (AU/UK/EU) (code: weekStart)"
    },
    {
      "figmaProperty": "maxChips",
      "values": "number",
      "default": "3 (2 when dense)",
      "codeProp": "chips a day renders before collapsing the rest into __more (code: maxChips)"
    }
  ]
}

  "changelog": [
    {
      "version": "1.2.1",
      "date": "2026-07-04",
      "change": "Fixed: the 29px ripple was visible at rest (0.4-opacity grey disc behind the thumb) — now opacity 0 at rest, raised only on hover/pressed, matching the documented MD3 state-layer behaviour."
    },
    {
      "version": "1.2.0",
      "date": "2026-06-18",
      "change": "Added Figma ↔ code mapping (props) table to the Variants section — properties, values, and defaults sourced from the Stardust Components Figma library."
    },
    {
      "version": "1.1.0",
      "date": "2026-06-12",
      "change": "Component CSS extracted to shared assets/css/components/toggle.css; anatomy rebuilt as deconstructed stack with hover part-highlighting; SVG diagram removed."
    },
    {
      "version": "1.0.1",
      "date": "2026-06-10",
      "change": "Knob resized 22→20px. Knob travel increased 16→20px. Off-position knob center at 7.5px (extends 2.5px beyond rail left end), on-position at 27.5px. More visual range relative to rail."
    },
    {
      "version": "1.0.0",
      "date": "2026-06-10",
      "change": "Initial component page. 2 states (on/off) × 5 variants. Rail 36×12px, knob 20×20px, ripple 29px. 200ms MD3 Standard easing. Focus via 2px knob border. Rail/knob depth intentional. Label always external. Built via component workshop workflow."
    }
  ],
  "props": [
    {
      "figmaProperty": "State",
      "values": "off, on",
      "default": "off",
      "codeProp": ".ds-toggle--on (absent = off; code: isOn)"
    },
    {
      "figmaProperty": "variant",
      "values": "Default, hover, pressed, focus, disabled",
      "default": "Default",
      "codeProp": "CSS pseudo-states + .ds-toggle--disabled (code: isDisabled)"
    },
    {
      "figmaProperty": "— (code-only)",
      "values": "id",
      "default": "—",
      "codeProp": "associates external <label for=\"…\">"
    }
  ]

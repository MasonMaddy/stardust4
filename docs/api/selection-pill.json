    {
      "version": "1.1.0",
      "date": "2026-06-18",
      "change": "Added Figma ↔ code mapping (props) table to the Variants section — properties, values, and defaults sourced from the Stardust Components Figma library. Documented that trailing controls (checkbox / radioButton / fab) are mutually exclusive."
    },
    {
      "version": "1.0.1",
      "date": "2026-06-12",
      "change": "Component CSS extracted to shared assets/css/components/selection-pill.css; anatomy rebuilt as deconstructed stack with hover part-highlighting; SVG diagram removed."
    },
    {
      "version": "1.0.0",
      "date": "2026-06-10",
      "change": "Initial component page. 5 states, 4 selectionTypes (none/dismiss/radio/checkbox), leadingIcon boolean. FAB bg tracks pill state. Button-inside-button ARIA pattern documented for dismiss. Focus/hover glow matches Button component. Built via component workshop workflow (Review → Spec → Sandbox → Build)."
    }

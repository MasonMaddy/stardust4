  "changelog": [
    {
      "version": "1.3.0",
      "date": "2026-06-12",
      "author": "Mason",
      "change": "Phase 3 (Mobile): select/multi/combobox open a Bottom Sheet under 768px with value/chip write-back (chips are the Pill component); combobox pins a search Input in the sheet (ds-sheet__search); date/time always native OS pickers (desktop web pattern to follow); keyboard avoidance via visualViewport documented."
    },
    {
      "version": "1.2.1",
      "date": "2026-06-12",
      "author": "Mason",
      "change": "Multi-select chips are now the Pill component (ds-pill --sm --green --minimal) — input-local chip styling removed; remove button nests inside the pill. Chevron pinned to the field edge when chips hide the display span."
    },
    {
      "version": "1.2.0",
      "date": "2026-06-12",
      "author": "Mason",
      "change": "Phase 2: Select, multi-select with chips + Select All, and searchable Combobox — flat dropdown menu (no elevation), right-hand checkboxes, surface-cyan selected rows, z-dropdown/surface-cyan-hover tokens. Desktop pattern; mobile bottom sheet is Phase 3."
    },
    {
      "version": "1.1.0",
      "date": "2026-06-12",
      "author": "Mason",
      "change": "Component CSS extracted to shared assets/css/components/input.css; duplicated ds-btn removed in favour of shared button.css; anatomy rebuilt as deconstructed stack."
    },
    {
      "version": "1.0.0",
      "date": "2026-06-11",
      "author": "Mason",
      "change": "Phase 1: text, email, password (eye toggle), search, send, textarea variants. All 5 states. 3 density tiers. Outside label preferred; inside label deprecated with dev warning. Accessibility: aria-invalid, aria-describedby wiring, 16px input font-size. Token references complete."
    }
  ],
  "props": [
    {
      "figmaProperty": "content",
      "values": "text, pills",
      "default": "text",
      "codeProp": "contentMode — pills in Phase 2 (select/combobox)"
    },
    {
      "figmaProperty": "type",
      "values": "—",
      "default": "text",
      "codeProp": "type: text | email | password | number | textarea | search | send"
    },
    {
      "figmaProperty": "state",
      "values": "unfilled, filled, focus, error, disabled",
      "default": "unfilled",
      "codeProp": "CSS pseudo-states + .ds-input--error + .ds-input--disabled"
    },
    {
      "figmaProperty": "outsideLabel",
      "values": "true, false",
      "default": "true",
      "codeProp": "label prop — preferred"
    },
    {
      "figmaProperty": "insideLabel",
      "values": "true, false",
      "default": "false",
      "codeProp": "insideLabel prop — deprecated, emits console.warn"
    },
    {
      "figmaProperty": "showLeadingIcon",
      "values": "true, false",
      "default": "true",
      "codeProp": "leadingIcon — icon name string or #leading slot"
    },
    {
      "figmaProperty": "showTrailingIcon",
      "values": "true, false",
      "default": "true",
      "codeProp": "trailingIcon — icon name string or #trailing slot"
    },
    {
      "figmaProperty": "clear",
      "values": "true, false",
      "default": "true",
      "codeProp": "clearable: boolean — renders clear button when field has a value"
    },
    {
      "figmaProperty": "helperText",
      "values": "true, false",
      "default": "false",
      "codeProp": "helperText string prop or #helper slot"
    },
    {
      "figmaProperty": "—",
      "values": "density",
      "default": "default",
      "codeProp": "density: default (56px) | comfortable (48px) | compact (40px)"
    }
  ]

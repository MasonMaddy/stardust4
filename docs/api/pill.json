  "changelog": [
    {
      "version": "1.3.0",
      "date": "2026-07-08",
      "change": "Added status variants (.ds-pill--status-*) consolidating the 8 legacy status badges (Active, Archived, Deleted, Expired, Inactive, Recalled, Upcoming, Waitlist) into one pill — each mapped to an existing semantic token colour (no new tokens). Added Status pills section + status→token mapping table and props/TS entries."
    },
    {
      "version": "1.2.0",
      "date": "2026-06-18",
      "change": "Added Figma ↔ code mapping (props) table to the Variants section — properties, values, and defaults sourced from the Stardust Components Figma library."
    },
    {
      "version": "1.1.0",
      "date": "2026-06-12",
      "change": "Component CSS extracted to shared assets/css/components/pill.css; Accessibility table re-expanded (focus, truncation, per-variant contrast); anatomy rebuilt as deconstructed stack with hover highlighting."
    },
    {
      "version": "1.0.0",
      "date": "2026-06-10",
      "change": "Initial component page — 36 variants (4 colour × 3 type × 3 size), non-interactive status/information label. New colour/surface/orange token added to tokens.css. Trailing icon changed from dismiss (Clear-cross-fill) to decorative flag (Flag-fill) in Figma update. Vue 3 / SwiftUI / Compose examples. Built via component workshop workflow (Review × 2 → Spec → Sandbox → Build)."
    }
  ],
  "props": [
    {
      "figmaProperty": "Color",
      "values": "Purple, Orange, Green, Grey",
      "default": "Green",
      "codeProp": ".ds-pill--purple / --orange / --green / --grey"
    },
    {
      "figmaProperty": "Size",
      "values": "sm, md, lg",
      "default": "sm",
      "codeProp": ".ds-pill--sm / --md / --lg — 24 / 32 / 44px"
    },
    {
      "figmaProperty": "type",
      "values": "solid, ghost, minimal",
      "default": "solid",
      "codeProp": ".ds-pill--solid / --ghost / --minimal"
    },
    {
      "figmaProperty": "— (code-only)",
      "values": "leadingIcon",
      "default": "true",
      "codeProp": "decorative icon slot"
    },
    {
      "figmaProperty": "— (code-only)",
      "values": "trailingIcon",
      "default": "true",
      "codeProp": "decorative trailing slot"
    },
    {
      "figmaProperty": "— (code-only)",
      "values": "status — active, upcoming, waitlist, archived, inactive, expired, deleted, recalled",
      "default": "none",
      "codeProp": ".ds-pill--status-active … --status-recalled — maps a status to a semantic token colour + label (see Status pills)"
    }
  ]

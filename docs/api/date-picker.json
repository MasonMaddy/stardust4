  "props": [
    {
      "figmaProperty": "mode",
      "values": "inline, input, sheet",
      "default": "inline",
      "codeProp": "presentation — inline card / input+popup / phone ds-sheet (code: mode)"
    },
    {
      "figmaProperty": "value",
      "values": "date | null",
      "default": "null",
      "codeProp": "the selected date; renders .ds-datepicker__day--selected (code: value)"
    },
    {
      "figmaProperty": "events",
      "values": "Set<iso>",
      "default": "—",
      "codeProp": "dates that render a .ds-datepicker__dot (code: events)"
    },
    {
      "figmaProperty": "min",
      "values": "date",
      "default": "—",
      "codeProp": "earliest selectable date — inclusive (code: min)"
    },
    {
      "figmaProperty": "max",
      "values": "date",
      "default": "—",
      "codeProp": "latest selectable date — inclusive (code: max)"
    },
    {
      "figmaProperty": "disablePast",
      "values": "false, true",
      "default": "false",
      "codeProp": "disables days before today; today stays selectable (code: disablePast)"
    },
    {
      "figmaProperty": "closeOnSelect",
      "values": "false, true",
      "default": "true",
      "codeProp": "input / sheet modes: close on pick (code: closeOnSelect)"
    },
    {
      "figmaProperty": "weekStart",
      "values": "monday, sunday",
      "default": "monday",
      "codeProp": "first grid column; default Monday (AU/UK/EU) (code: weekStart)"
    }
  ]
}

  "props": [
    {
      "figmaProperty": "layout",
      "values": "dropzone, compact",
      "default": "dropzone",
      "codeProp": ".ds-fileupload--compact (absent = dropzone; code: compact)"
    },
    {
      "figmaProperty": "accept",
      "values": "all, images, csv",
      "default": "all",
      "codeProp": "native accept on the input — gates the dialog and drag validation (code: accept)"
    },
    {
      "figmaProperty": "multiple",
      "values": "false, true",
      "default": "true",
      "codeProp": "native multiple on the input; single mode replaces (code: multiple)"
    },
    {
      "figmaProperty": "disabled",
      "values": "false, true",
      "default": "false",
      "codeProp": ".ds-fileupload__zone--disabled + disabled on the input (code: disabled)"
    },
    {
      "figmaProperty": "presentation",
      "values": "auto, touch",
      "default": "auto",
      "codeProp": ".ds-fileupload--touch forces the tap presentation; auto swaps it ≤640px (code: touch)"
    },
    {
      "figmaProperty": "— (code-only)",
      "values": "number",
      "default": "—",
      "codeProp": "client-side max-size check → per-file .ds-fileupload__item--error (code: maxBytes)"
    }
  ]
}

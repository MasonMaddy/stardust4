  "changelog": [
    {
      "version": "1.2.1",
      "date": "2026-07-04",
      "change": "Fixed: tertiary hover background moved to colour/orange/100 — it previously used feedback/warning/subtle, which aliases the same orange-50 hex as the resting surface/orange, so hovering produced no visual change."
    },
    {
      "version": "1.2.0",
      "date": "2026-06-18",
      "change": "Added Figma ↔ code mapping (props) table to the Variants section — properties, values, and defaults sourced from the Stardust Components Figma library."
    },
    {
      "version": "1.1.0",
      "date": "2026-06-12",
      "change": "Component CSS extracted to shared assets/css/components/fab.css; Accessibility table re-expanded (native button, keyboard, per-size touch targets, fixed xl placement); anatomy rebuilt as deconstructed stack with hover highlighting."
    },
    {
      "version": "1.0.0",
      "date": "2026-06-10",
      "change": "Initial component page. 4 types × 4 sizes × 6 states. xl size added with optional text label (Extended FAB). md corrected to 32px (grid-aligned from original 36px). inverse state renamed to filled. Focus upgraded to 2px solid border (no box-shadow). Token name colour/focus/default → colour/focus/primary. No elevation. Built via component workshop workflow (Review × 1 → Spec → Sandbox → Build)."
    }
  ],
  "props": [
    {
      "figmaProperty": "Type",
      "values": "default, secondary, tertiary, inverse",
      "default": "default",
      "codeProp": ".ds-fab (default) / --secondary / --tertiary / --inverse"
    },
    {
      "figmaProperty": "size",
      "values": "sm, md, lg, xl",
      "default": "lg",
      "codeProp": ".ds-fab--sm / --md / --lg / --xl — 24 / 32 / 44 / 56px"
    },
    {
      "figmaProperty": "state",
      "values": "default, filled, hover, focus, pressed, disabled",
      "default": "default",
      "codeProp": ".ds-fab--filled (saturated, for coloured bg) + CSS pseudo-states + .ds-fab--disabled"
    },
    {
      "figmaProperty": "— (code-only)",
      "values": "showText",
      "default": "false",
      "codeProp": "xl only — label beside icon (Extended FAB)"
    },
    {
      "figmaProperty": "— (code-only)",
      "values": "accessibilityLabel",
      "default": "—",
      "codeProp": "required when showText=false"
    }
  ]

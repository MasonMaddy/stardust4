  "props": [
    {
      "figmaProperty": "columns",
      "values": "column[] (key, label, type: text/date/number/status, primary, num)",
      "default": "—",
      "codeProp": "drives the header + cell renderers (code: columns)"
    },
    {
      "figmaProperty": "sortable",
      "values": "false, true",
      "default": "false",
      "codeProp": "renders .ds-datatable__sort buttons + aria-sort (code: onSort)"
    },
    {
      "figmaProperty": "selectable",
      "values": "false, true",
      "default": "false",
      "codeProp": "adds the .ds-datatable__select column + indeterminate select-all (code: selected/onToggleRow)"
    },
    {
      "figmaProperty": "density",
      "values": "comfortable, compact",
      "default": "comfortable",
      "codeProp": ".ds-datatable--{density} (code: density)"
    },
    {
      "figmaProperty": "zebra",
      "values": "false, true",
      "default": "false",
      "codeProp": ".ds-datatable--zebra (code: zebra)"
    },
    {
      "figmaProperty": "stickyHeader",
      "values": "false, true",
      "default": "false",
      "codeProp": ".ds-datatable__wrap--sticky — header pins, body scrolls (code: sticky)"
    },
    {
      "figmaProperty": "rowActions",
      "values": "action[] | none",
      "default": "none",
      "codeProp": "adds the kebab column; menu portals to .ds-datatable__menu-layer (code: onAction)"
    },
    {
      "figmaProperty": "status",
      "values": "data, loading, empty, error",
      "default": "data",
      "codeProp": "selects the body render — rows, skeleton, empty block, or ds-message-box (code: status)"
    },
    {
      "figmaProperty": "pagination",
      "values": "false, true",
      "default": "false",
      "codeProp": "renders .ds-datatable__footer outside the scroll region (code: page/perPage)"
    },
    {
      "figmaProperty": "responsive / cards",
      "values": "false, true",
      "default": "false",
      "codeProp": ".ds-datatable--responsive (auto-collapse ≤640px) or --cards (forced) (code: responsive/forceCards)"
    },
    {
      "figmaProperty": "— (toolbar)",
      "values": "facet[]: multi · dateRange · numericRange · boolean",
      "default": "—",
      "codeProp": "ds-datatable-toolbar + ds-datatable-filter modal; each active facet → one removable chip"
    },
    {
      "figmaProperty": "— (wide)",
      "values": "scroll+ (pinned), row-expand, stacked",
      "default": "scroll+",
      "codeProp": ".ds-datatable__hshell with __pin columns; the chosen 10+ column pattern"
    }
  ]
}

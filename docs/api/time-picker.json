  "props": [
    {
      "figmaProperty": "showSeconds",
      "values": "false, true",
      "default": "false",
      "codeProp": "renders the ss .ds-timepicker__seg + separator (code: showSeconds)"
    },
    {
      "figmaProperty": "prefill",
      "values": "false, true",
      "default": "false",
      "codeProp": "opt-in: fill the current time on first focus of an empty field (code: prefillOnFocus)"
    },
    {
      "figmaProperty": "granularity",
      "values": "15, 30 (min)",
      "default": "30",
      "codeProp": "step of the tap-assist list options (code: listStepMinutes)"
    },
    {
      "figmaProperty": "state",
      "values": "default, error, disabled",
      "default": "default",
      "codeProp": ".ds-input--error / .ds-input--disabled on the root (code: state)"
    },
    {
      "figmaProperty": "— (code-only)",
      "values": "string",
      "default": "—",
      "codeProp": "labelledby wiring: field role=\"group\" → the label id"
    },
    {
      "figmaProperty": "— (code-only)",
      "values": "string",
      "default": "''",
      "codeProp": "value as { hh, mm, ss?, meridiem }; empty is valid until a form requires it (code: value)"
    }
  ]

  "changelog": [
    {
      "version": "1.3.0",
      "date": "2026-06-12",
      "author": "Mason",
      "change": "Component CSS extracted to shared assets/css/components/button.css (single source of truth; font-weight/motion tokenised). Anatomy section rebuilt as deconstructed stack: live unannotated preview + per-part rows with hover/focus highlighting (shared anatomy.js + main.css styles). SVG callout diagram removed."
    },
    {
      "version": "1.2.0",
      "date": "2026-06-10",
      "author": "Mason",
      "change": "Icon-only variant (text=false in Figma): square 48×48, all 4 types + all states. Loading variant: spinner replaces lead icon, pointer-events: none, 0.75s linear arc animation with currentColor, slows on prefers-reduced-motion. TypeScript interface updated (iconOnly, isLoading). Open question 6 resolved."
    },
    {
      "version": "1.1.0",
      "date": "2026-06-02",
      "author": "Mason",
      "change": "Rewritten to match Figma v1.1: 4 types, 40 variants, token-only demo CSS, destructive added, FAB/size/loading removed."
    },
    {
      "version": "1.0.0",
      "date": "2026-06-02",
      "author": "Mason",
      "change": "Initial WIP (superseded)"
    }
  ],
  "props": [
    {
      "figmaProperty": "type",
      "values": "solid, ghost, minimal, destructive",
      "default": "solid",
      "codeProp": "type"
    },
    {
      "figmaProperty": "state",
      "values": "default, hover, focus, pressed, disabled",
      "default": "default",
      "codeProp": "CSS pseudo-states / isDisabled"
    },
    {
      "figmaProperty": "size",
      "values": "hug, full width",
      "default": "hug",
      "codeProp": "fullWidth: boolean"
    },
    {
      "figmaProperty": "text",
      "values": "true, false",
      "default": "true",
      "codeProp": "iconOnly: boolean — when false, renders square 48×48 with icon only"
    },
    {
      "figmaProperty": "leadIcon",
      "values": "true, false",
      "default": "false",
      "codeProp": "leadIcon"
    },
    {
      "figmaProperty": "trailIcon",
      "values": "true, false",
      "default": "false",
      "codeProp": "trailIcon"
    },
    {
      "figmaProperty": "—",
      "values": "loading",
      "default": "false",
      "codeProp": "isLoading: boolean — spinner replaces leading icon, pointer-events blocked"
    }
  ]
